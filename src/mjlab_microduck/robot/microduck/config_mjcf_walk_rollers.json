{
    "url": "https://cad.onshape.com/documents/804927696f06d877f3f1803e/w/0de7a9efe982c0c667e589c0/e/eee1ab796d84f4ff324d3a02",
    "outputFormat": "mujoco",
    "robot_name": "microduck",
    "output_filename": "robot_walk_rollers",
    "simplify_stls": true,
    "max_stl_size": 1.0,
    "ignore": {
        "*": "collision",
        "!leg_plate": "collision",
        "!bottom_shell": "collision",
        "!roller_wheel": "collision"
    },
    "additional_xml": [
        "joints_properties.xml",
        "sensors.xml",
        "additional.xml"
    ],
    "post_import_commands": [
        "sed -i 's/class=\"collision\"\\(.*mesh=\"bottom_shell\"\\)/class=\"self_collision_only\"\\1/g' robot_walk_rollers.xml",
        "sed -i 's/class=\"collision\"\\(.*mesh=\"leg_plate\"\\)/class=\"self_collision_only\"\\1/g' robot_walk_rollers.xml",
        "sed -i 's/body name=\"trunk_base\" pos=\"[^\"]*\"/body name=\"trunk_base\" pos=\"0 0 0.14\"/' robot_walk_rollers.xml",
        "sed -i '/<!-- Part foot_tpu_bottom -->/{n; n; s/class=\"collision\"/name=\"left_foot_collision\" class=\"collision\"/}' robot_walk_rollers.xml",
        "sed -i '/<!-- Part foot_tpu_bottom_2 -->/{n; n; s/class=\"collision\"/name=\"right_foot_collision\" class=\"collision\"/}' robot_walk_rollers.xml",
        "sed -i 's/ inheritrange=\"1\"//g' robot_walk_rollers.xml",
        "sed -i 's|<site[^>]*name=\"torso_camera\"[^>]*pos=\"\\([^\"]*\\)\"[^>]*/>|&\\n      <camera name=\"torso_camera\" pos=\"\\1\" quat=\"0.5 0.5 -0.5 -0.5\"/>|' robot_walk_rollers.xml",
        "sed -i 's|<site[^>]*name=\"head_camera\"[^>]*pos=\"\\([^\"]*\\)\"[^>]*/>|&\\n              <camera name=\"head_camera\" pos=\"\\1\" quat=\"0 0 -1 0\"/>|' robot_walk_rollers.xml",
        "sed -i '/name=\"passive_[LR][FR]wheel\" joint=\"passive_[LR][FR]wheel\"/d' robot_walk_rollers.xml"
    ],
    "joint_properties": {
        "default": {
            "class": "chosen_actuator"
        },
        "passive_LFwheel": {
            "class": "passive_wheel"
        },
        "passive_LRwheel": {
            "class": "passive_wheel"
        },
        "passive_RFwheel": {
            "class": "passive_wheel"
        },
        "passive_RRwheel": {
            "class": "passive_wheel"
        }
    }
}