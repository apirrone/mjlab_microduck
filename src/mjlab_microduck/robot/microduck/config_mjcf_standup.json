{
    "url": "https://cad.onshape.com/documents/804927696f06d877f3f1803e/w/3df6f6a8dcea50fb5658e3c0/e/eee1ab796d84f4ff324d3a02",
    "outputFormat": "mujoco",
    "robot_name": "microduck",
    "output_filename": "robot_standup",
    "simplify_stls": true,
    "max_stl_size": 1.0,
    "ignore": {
        "*": "collision",
        "!foot_tpu_bottom": "collision",
        "!leg_plate": "collision",
        "!bottom_shell": "collision",
        "!top_shell": "collision",
        "!head_top": "collision",
        "!head_top_base_plate": "collision",
        "!trunk_base": "collision",
        "!foot": "collision",
    },
    "additional_xml": [
        "joints_properties.xml",
        "sensors.xml",
        "additional.xml"
    ],
    "post_import_commands": [
        "sed -i 's/body name=\"trunk_base\" pos=\"[^\"]*\"/body name=\"trunk_base\" pos=\"0 0 0.12\"/' robot_standup.xml",
        "sed -i '/<!-- Part foot_tpu_bottom -->/{n; n; s/class=\"collision\"/name=\"left_foot_collision\" class=\"collision\"/}' robot_standup.xml",
        "sed -i '/<!-- Part foot_tpu_bottom_2 -->/{n; n; s/class=\"collision\"/name=\"right_foot_collision\" class=\"collision\"/}' robot_standup.xml",
        "sed -i 's/ inheritrange=\"1\"//g' robot_standup.xml",
        "sed -i 's|<site[^>]*name=\"torso_camera\"[^>]*pos=\"\\([^\"]*\\)\"[^>]*/>|&\\n      <camera name=\"torso_camera\" pos=\"\\1\" quat=\"0.5 0.5 -0.5 -0.5\"/>|' robot_standup.xml",
        "sed -i 's|<site[^>]*name=\"head_camera\"[^>]*pos=\"\\([^\"]*\\)\"[^>]*/>|&\\n              <camera name=\"head_camera\" pos=\"\\1\" quat=\"0 0 -1 0\"/>|' robot_standup.xml"
    ],
    "joint_properties": {
        "default": {
            "class": "chosen_actuator"
        }
    }
}